# ╔═══════════════════════════════════════════════════════════════╗
# ║⚑ ⩜ RADICAL TMUX — v1.0                                        ║
# ╚═══════════════════════════════════════════════════════════════╝

# ============================================
#  Cyberpunk Dystopian Theme for Oh My Tmux
# ============================================

# Ativa status bar no topo
set -g status-position top
set -g default-terminal "tmux-256color"
set -as terminal-overrides ',xterm-256color:RGB'
set -g allow-passthrough on
set -ga update-environment TERM
set -ga update-environment TERM_PROGRAM
set -g status-position top

# -- window tab style ----------------------------------------------------------
tmux_conf_theme_window_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_window_status_bg="$tmux_conf_theme_colour_2"
tmux_conf_theme_window_status_attr="none"
# Formato da aba inativa (com a setinha fina)
tmux_conf_theme_window_status_format=" #I #W "

tmux_conf_theme_window_status_current_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_window_status_current_bg="$tmux_conf_theme_colour_4"
tmux_conf_theme_window_status_current_attr="bold"
# Formato da aba ativa (Aqui a mágica acontece)
tmux_conf_theme_window_status_current_format=" #I #W "

# -- Manter os atalhos originais do TMUX? (vanilla tmux)
tmux_conf_preserve_stock_bindings=false

# -- Controla se o tmux vai te perguntar o nome da sessão ao criar uma nova 
tmux_conf_new_session_prompt=false
tmux_conf_new_session_retain_current_path=true

# -- windows & pane creation ---------------------------------------------------
tmux_conf_new_window_retain_current_path=true
tmux_conf_new_window_reconnect_ssh=false
tmux_conf_new_pane_retain_current_path=true
tmux_conf_new_pane_reconnect_ssh=false

# -- display -------------------------------------------------------------------
tmux_conf_24b_colour=auto

# -- CYBERPUNK DISTÓPICO (NOVA PALETA) -----------------------------------------
tmux_conf_theme=enabled
tmux_conf_theme_colour_1="#08090a"    # Fundo Principal (Deep Void)
tmux_conf_theme_colour_2="#1a103d"    # Fundo Secundário (Midnight)
tmux_conf_theme_colour_3="#00f3ff"    # Ciano (Texto Principal)
tmux_conf_theme_colour_4="#ff00ff"    # Rosa Neon (Aba Ativa)
tmux_conf_theme_colour_5="#fff000"    # Amarelo (Destaques)
tmux_conf_theme_colour_6="#08090a"    # Fundo Status Left
tmux_conf_theme_colour_7="#00f3ff"    # Texto Status Left
tmux_conf_theme_colour_8="#08090a"    # Fundo Extra
tmux_conf_theme_colour_9="#fff000"    # Separador Amarelo
tmux_conf_theme_colour_10="#ff00ff"   # Separador Rosa
tmux_conf_theme_colour_11="#00ff41"   # Verde Ácido (Uptime/OK)
tmux_conf_theme_colour_12="#00f3ff"   # Texto Status Right
tmux_conf_theme_colour_13="#e0e0ff"   # Cinza Claro (Texto)
tmux_conf_theme_colour_14="#08090a"   # Fundo Final Right
tmux_conf_theme_colour_15="#08090a"   # Fundo Status Base
tmux_conf_theme_colour_16="#ff003c"   # Vermelho Alerta
tmux_conf_theme_colour_17="#00f3ff"   # Ciano Final

# -- window style --------------------------------------------------------------
tmux_conf_theme_window_fg="default"
tmux_conf_theme_window_bg="default"

# -- pane borders --------------------------------------------------------------
tmux_conf_theme_highlight_focused_pane=true
tmux_conf_theme_focused_pane_bg="default"

tmux_conf_theme_pane_border_style=thin
tmux_conf_theme_pane_border="$tmux_conf_theme_colour_3"
tmux_conf_theme_pane_active_border="$tmux_conf_theme_colour_4"
%if #{>=:#{version},3.2}
tmux_conf_theme_pane_active_border="#{?pane_in_mode,$tmux_conf_theme_colour_5,#{?synchronize-panes,$tmux_conf_theme_colour_16,$tmux_conf_theme_colour_4}}"
%endif

tmux_conf_theme_pane_indicator="$tmux_conf_theme_colour_4"
tmux_conf_theme_pane_active_indicator="$tmux_conf_theme_colour_5"

# -- message / command bar -----------------------------------------------------
tmux_conf_theme_message_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_message_bg="$tmux_conf_theme_colour_5"
tmux_conf_theme_message_attr="bold"

tmux_conf_theme_message_command_fg="$tmux_conf_theme_colour_5"
tmux_conf_theme_message_command_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_message_command_attr="bold"

tmux_conf_theme_mode_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_mode_bg="$tmux_conf_theme_colour_5"
tmux_conf_theme_mode_attr="bold"

# -- status line base style ----------------------------------------------------
tmux_conf_theme_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_status_bg="default"
tmux_conf_theme_status_attr="none"


# -- terminal title ------------------------------------------------------------
tmux_conf_theme_terminal_title="⬡ #S ▸ #W"

# -- window tab style ----------------------------------------------------------
tmux_conf_theme_window_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_window_status_bg="$tmux_conf_theme_colour_2"
tmux_conf_theme_window_status_attr="none"
tmux_conf_theme_window_status_format=" #I ▸ #W#{?window_bell_flag, !, }#{?window_zoomed_flag, ⬡, } "

tmux_conf_theme_window_status_current_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_window_status_current_bg="$tmux_conf_theme_colour_4"
tmux_conf_theme_window_status_current_attr="bold"
tmux_conf_theme_window_status_current_format=" #I ▸ #W#{?window_bell_flag, !, }#{?window_zoomed_flag, ⬡, } "

tmux_conf_theme_window_status_activity_fg="$tmux_conf_theme_colour_5"
tmux_conf_theme_window_status_activity_bg="default"
tmux_conf_theme_window_status_activity_attr="bold"

tmux_conf_theme_window_status_bell_fg="$tmux_conf_theme_colour_16"
tmux_conf_theme_window_status_bell_bg="default"
tmux_conf_theme_window_status_bell_attr="blink,bold"

tmux_conf_theme_window_status_last_fg="$tmux_conf_theme_colour_4"
tmux_conf_theme_window_status_last_bg="$tmux_conf_theme_colour_2"
tmux_conf_theme_window_status_last_attr="none"


# -- Powerline separators ------------------------------------------------------
tmux_conf_theme_left_separator_main='\uE0B0'
tmux_conf_theme_left_separator_sub='\uE0B1'
tmux_conf_theme_right_separator_main='\uE0B2'
tmux_conf_theme_right_separator_sub='\uE0B3'

# -- CONFIGURAÇÃO DO PAINEL ESQUERDO (RADAR DE SESSÃO) -------------------------

# A string de dados permanece inalterada, mantendo a integridade da arma ASCII
#tmux_conf_theme_status_left=" ⚑ ⩜ (う-´)▄︻デ═══一*++ #S | ↑#{?uptime_y, #{uptime_y}y,}#{?uptime_d, #{uptime_d}d,}#{?uptime_h, #{uptime_h}h,}#{?uptime_m, #{uptime_m}m,} "

# -- CONSTANTES TERMÓNICAS (PALETA CIBERNÉTICA EXPANDIDA) -----------------------
# Adicionamos o isótopo de Âmbar para o espectro do Uptime
tmux_conf_theme_colour_18="#ff8c00"    # Laranja de Sódio (Uptime)

# -- CONFIGURAÇÃO DO RADAR ESQUERDO (STATUS LEFT) ------------------------------
# Substituímos o fuzil estático pela função variável #{_rifle}
tmux_conf_theme_status_left=" ⚑ ⩜ (う-´)▄︻デ═══一*++ #S | ↑#{?uptime_y, #{uptime_y}y,}#{?uptime_d, #{uptime_d}d,}#{?uptime_h, #{uptime_h}h,}#{?uptime_m, #{uptime_m}m,} "

# Definição dos fotões de cor para o texto (Foreground)
# 1. none: Permite que a função do fuzil controle a sua própria cor interna
# 2. colour_18: O nosso Laranja Âmbar para o segundo segmento (Uptime)
# tmux_conf_theme_status_left_fg="none,$tmux_conf_theme_colour_18,$tmux_conf_theme_colour_8"

# Aqui calculamos os vetores de cor frontal (Foreground)
# O primeiro valor ($colour_6) aplica-se à Sessão. 
# O SEGUNDO valor ($colour_18) aplica-se agora ao Uptime em LARANJA.
tmux_conf_theme_status_left_fg="$tmux_conf_theme_colour_6,$tmux_conf_theme_colour_18,$tmux_conf_theme_colour_8"

# Aqui calculamos os vetores de fundo (Background)
# Mantive o fundo do Uptime como Deep Void ($colour_1) para o laranja não sofrer interferência
tmux_conf_theme_status_left_bg="$tmux_conf_theme_colour_9,$tmux_conf_theme_colour_1,$tmux_conf_theme_colour_11"

# Atributos de renderização (Negrito para o primeiro segmento, normal para o uptime)
tmux_conf_theme_status_left_attr="bold,none,none"
# -- status left ---------------------------------------------------------------
#tmux_conf_theme_status_left=" ⚑ ⩜ (う-´)▄︻デ═══一*++ #S | ↑#{?uptime_y, #{uptime_y}y,}#{?uptime_d, #{uptime_d}d,}#{?uptime_h, #{uptime_h}h,}#{?uptime_m, #{uptime_m}m,} "
#tmux_conf_theme:wq_status_left_fg="$tmux_conf_theme_colour_6,$tmux_conf_theme_colour_7,$tmux_conf_theme_colour_8"
#tmux_conf_theme_status_left_bg="$tmux_conf_theme_colour_9,$tmux_conf_theme_colour_10,$tmux_conf_theme_colour_11"
#tmux_conf_theme_status_left_attr="bold,none,none"


# -- status right --------------------------------------------------------------
tmux_conf_theme_status_right="#{prefix}#{mouse}#{pairing}#{synchronized} #{loadavg} | #{?battery_status,#{battery_status},}#{?battery_bar,#{battery_bar},}#{?battery_percentage, #{battery_percentage},} | RADICAL@BRAGA.USS "
tmux_conf_theme_status_right_fg="$tmux_conf_theme_colour_12,$tmux_conf_theme_colour_13,$tmux_conf_theme_colour_14"
tmux_conf_theme_status_right_bg="$tmux_conf_theme_colour_15,$tmux_conf_theme_colour_16,$tmux_conf_theme_colour_17"
tmux_conf_theme_status_right_attr="none,none,bold"


# -- indicators ----------------------------------------------------------------
tmux_conf_theme_pairing="⚇"
tmux_conf_theme_pairing_fg="none"
tmux_conf_theme_pairing_bg="none"
tmux_conf_theme_pairing_attr="none"

tmux_conf_theme_prefix="⌨"
tmux_conf_theme_prefix_fg="none"
tmux_conf_theme_prefix_bg="none"
tmux_conf_theme_prefix_attr="none"

tmux_conf_theme_mouse="↗"
tmux_conf_theme_mouse_fg="none"
tmux_conf_theme_mouse_bg="none"
tmux_conf_theme_mouse_attr="none"

tmux_conf_theme_root="▲ROOT▲"
tmux_conf_theme_root_fg="$tmux_conf_theme_colour_16"
tmux_conf_theme_root_bg="none"
tmux_conf_theme_root_attr="bold,blink"

tmux_conf_theme_synchronized="⚏ SYNC"
tmux_conf_theme_synchronized_fg="$tmux_conf_theme_colour_5"
tmux_conf_theme_synchronized_bg="none"
tmux_conf_theme_synchronized_attr="bold"

# -- battery -------------------------------------------------------------------
tmux_conf_battery_bar_symbol_full="█"
tmux_conf_battery_bar_symbol_empty="░"
tmux_conf_battery_bar_length="auto"
tmux_conf_battery_bar_palette="gradient"
tmux_conf_battery_hbar_palette="gradient"
tmux_conf_battery_vbar_palette="gradient"
tmux_conf_battery_status_charging="⚡"
tmux_conf_battery_status_discharging="▼"

# -- clipboard -----------------------------------------------------------------
tmux_conf_copy_to_os_clipboard=false

# -- urlscan -------------------------------------------------------------------
tmux_conf_urlscan_options="--compact --dedupe"

# -- user customizations -------------------------------------------------------
set -g history-limit 50000
set -g mouse on

bind r source-file '#{TMUX_CONF}' \; display '⬡ CONFIG RELOADED ⬡'
bind m run "cut -c3- '#{TMUX_CONF}' | sh -s _toggle_mouse" \; display '↗ MOUSE: #{?#{mouse},ONLINE,OFFLINE}'

set-option -g status-position top

unbind c
bind c command-prompt -p "⚑ Nova sessão:" "new-session -c '#{pane_current_path}' -s '%%'"

# -- tpm -----------------------------------------------------------------------
tmux_conf_update_plugins_on_launch=true
tmux_conf_update_plugins_on_reload=true
tmux_conf_uninstall_plugins_on_reload=true

bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel "xclip -selection clipboard -in"
# -- custom variables ----------------------------------------------------------

# ------------------------------------------------------------------------------

# # /!\ do not remove the following line
# EOF
